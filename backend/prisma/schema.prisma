generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  password     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Game {
  id          String   @id @default(uuid())
  name        String
  publisher   String
  imageUrl    String
  description String?
  isPopular    Boolean       @default(false)
  products     Product[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String   // e.g., "50 Diamonds"
  price       Float    // Price in IDR
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id])
  transactions Transaction[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  gameUserId    String   // The ID of the player in the game to be topped up
  gameZoneId    String?  // The Server/Zone ID if required by the game
  status        String   @default("PENDING") // PENDING, SUCCESS, FAILED
  paymentCode   String?  // Custom VA code or QRIS link
  amount        Float
  paymentMethod String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
